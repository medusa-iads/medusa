          "refId": "B"
        },
        {
          "expr": "medusa_battery_harm_ratio{network=~\"$network\", battery=~\"$battery\"} and on() medusa:live",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "refId": "C"
        }
      ],
      "transformations": [
