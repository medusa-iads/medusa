  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["medusa", "battery"],
  "templating": {
    "list": [
      {
        "name": "network",
        "type": "query",
        "query": "label_values(medusa_batteries_total, network)",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "label": "IADS Network",
        "refresh": 2
      },
      {
        "name": "battery",
        "type": "query",
        "query": "label_values(medusa_battery_info{network=~\"$network\"}, battery)",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "label": "Battery",
        "refresh": 2
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "title": "Medusa Battery Details",
