          "legendFormat": "",
          "format": "table",
          "instant": true,
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "refId": "A"
        },
        {
          "expr": "medusa_battery_harm_defenders{network=~\"$network\", battery=~\"$battery\"} and on() medusa:live",
          "legendFormat": "",
