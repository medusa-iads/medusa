      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "medusa_battery_last_chance{network=~\"$network\", battery=~\"$battery\"} and on() medusa:live",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "refId": "A"
        },
        {
          "expr": "medusa_battery_last_chance_shots_remaining{network=~\"$network\", battery=~\"$battery\"} and on() medusa:live",
          "legendFormat": "",
